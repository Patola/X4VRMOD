+            g_sbs.shm = (uint8_t *)p; g_sbs.shmSize = size;
+            g_sbs.hdr = (X4VRShmHeader *)p;
+            g_sbs.data = g_sbs.shm + X4VR_DATA_OFFSET;
+            g_sbs.hdr->version = X4VR_SHM_VERSION;
+            g_sbs.hdr->width = w; g_sbs.hdr->height = h; g_sbs.hdr->stride = stride;
+            g_sbs.hdr->format = fmt; g_sbs.hdr->buffers = X4VR_SHM_BUFFERS;
+            g_sbs.hdr->buffer_bytes = bufBytes; g_sbs.hdr->data_offset = X4VR_DATA_OFFSET;
+            __atomic_store_n(&g_sbs.hdr->seq, g_sbs.seq, __ATOMIC_RELEASE);
+            __atomic_store_n(&g_sbs.hdr->magic, X4VR_SHM_MAGIC, __ATOMIC_RELEASE);
+            Logger::info("X4VR: shm ready " + std::to_string(w) + "x" + std::to_string(h) +
+                         " fmt=" + std::to_string(fmt));
+            return true;
+        }
+
+        bool sbsEnsureVk(LogicalDevice *dev, uint32_t w, uint32_t h) {
+            DeviceDispatch &vkd = dev->vkd;
+            if (g_sbs.dev != dev) {
+                g_sbs.dev = dev;
+                VkCommandPoolCreateInfo pci = { VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO };
+                pci.flags = VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT;
+                pci.queueFamilyIndex = dev->queueFamilyIndex;
+                if (vkd.CreateCommandPool(dev->device, &pci, nullptr, &g_sbs.pool) != VK_SUCCESS)
+                    { g_sbs.enabled = false; return false; }
+                for (int i = 0; i < SBS_SLOTS; i++) {
+                    auto &s = g_sbs.slot[i];
+                    VkCommandBufferAllocateInfo cai = { VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO };
+                    cai.commandPool = g_sbs.pool;
+                    cai.level = VK_COMMAND_BUFFER_LEVEL_PRIMARY;
+                    cai.commandBufferCount = 1;
+                    if (vkd.AllocateCommandBuffers(dev->device, &cai, &s.cmd) != VK_SUCCESS)
+                        { g_sbs.enabled = false; return false; }
+                    initializeDispatchTable(s.cmd, dev->device);
+                    VkSemaphoreCreateInfo sci = { VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO };
+                    vkd.CreateSemaphore(dev->device, &sci, nullptr, &s.sem);
+                    VkFenceCreateInfo fci = { VK_STRUCTURE_TYPE_FENCE_CREATE_INFO };
+                    vkd.CreateFence(dev->device, &fci, nullptr, &s.fence);
+                }
+            }
+            VkDeviceSize bytes = (VkDeviceSize)w * h * 4;
+            if (g_sbs.slot[0].staging && g_sbs.bytes == bytes) return true;
+            // (re)allocate per-slot staging; drain any in-flight copy first.
+            for (int i = 0; i < SBS_SLOTS; i++) {
+                auto &s = g_sbs.slot[i];
+                if (s.inFlight) {
+                    vkd.WaitForFences(dev->device, 1, &s.fence, VK_TRUE, UINT64_MAX);
+                    vkd.ResetFences(dev->device, 1, &s.fence);
+                    s.inFlight = false;
+                }
+                if (s.staging) { vkd.DestroyBuffer(dev->device, s.staging, nullptr); s.staging = VK_NULL_HANDLE; }
+                if (s.mem) { vkd.FreeMemory(dev->device, s.mem, nullptr); s.mem = VK_NULL_HANDLE; }
+                // HOST_CACHED is essential: we memcpy READ 13 MB/frame out of
+                // this buffer. Without it AMD hands back write-combined memory,
+                // whose CPU reads are pathologically slow (tens of ms/frame) —
+                // that, not the fence, was the 45fps wall. COHERENT too so we
+                // need no manual cache invalidation before reading.
+                createBuffer(dev, bytes, VK_BUFFER_USAGE_TRANSFER_DST_BIT,
+                             VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT |
+                             VK_MEMORY_PROPERTY_HOST_CACHED_BIT |
+                             VK_MEMORY_PROPERTY_HOST_COHERENT_BIT,
+                             s.staging, s.mem);
+                if (vkd.MapMemory(dev->device, s.mem, 0, bytes, 0, &s.mapped) != VK_SUCCESS)
+                    { g_sbs.enabled = false; return false; }
+            }
+            g_sbs.bytes = bytes; g_sbs.w = w; g_sbs.h = h;
+            return true;
+        }
+
+        // Copy swapchain image -> a ring staging slot -> shm. Returns the
+        // semaphore the present must wait on (so the image's layout is restored
+        // before present), or VK_NULL_HANDLE to fall back to the caller's.
+        VkSemaphore sbsExportFrame(LogicalDevice *dev, VkImage image,
+                                   uint32_t w, uint32_t h, VkFormat format,
+                                   VkSemaphore waitSem) {
+            DeviceDispatch &vkd = dev->vkd;
+            bool resizing = (g_sbs.w != w || g_sbs.h != h);
+
+            if (!sbsEnsureShm(w, h, sbsMapFormat(format))) return VK_NULL_HANDLE;
+            if (!sbsEnsureVk(dev, w, h)) return VK_NULL_HANDLE;
+
+            auto &s = g_sbs.slot[g_sbs.cur];
+
+            // Reclaim this slot. Its copy (if any) was submitted SBS_SLOTS frames
+            // ago, so its fence is virtually always already signalled — the wait
+            // does not stall the pipeline. Publish its data, then reuse the slot.
+            if (s.inFlight) {
+                // Diagnostic: time the wait on this (SBS_SLOTS-old) fence. If it
+                // is consistently long, the CPU is blocking on the GPU (ring too
+                // shallow / GPU behind); if it is ~0, any 45fps cap is elsewhere
+                // (e.g. the present path / compositor), not this fence.
+                auto t0 = std::chrono::steady_clock::now();
+                vkd.WaitForFences(dev->device, 1, &s.fence, VK_TRUE, UINT64_MAX);
+                double waitMs = std::chrono::duration<double, std::milli>(
+                    std::chrono::steady_clock::now() - t0).count();
+                g_sbs.diagWaitMs += waitMs;
+                if (waitMs > 0.2) g_sbs.diagBlocked++;
+                vkd.ResetFences(dev->device, 1, &s.fence);
+                if (!resizing) {
+                    uint32_t idx = (uint32_t)(g_sbs.seq % X4VR_SHM_BUFFERS);
+                    memcpy(g_sbs.data + (size_t)idx * g_sbs.hdr->buffer_bytes,
+                           s.mapped, g_sbs.hdr->buffer_bytes);
+                    g_sbs.seq++;
+                    __atomic_store_n(&g_sbs.hdr->seq, g_sbs.seq, __ATOMIC_RELEASE);
+                }
+                s.inFlight = false;
+                // Opt-in diagnostic (X4VR_DIAG=1): fence-wait avg should be ~0
+                // and blocked ~0 when the pipeline is healthy.
+                static const bool diag = []{ const char *e = std::getenv("X4VR_DIAG");
+                                             return e && e[0] && e[0] != '0'; }();
+                if (diag && ++g_sbs.diagFrames % 300 == 0) {
+                    Logger::info("X4VR diag: 300 frames, fence-wait avg " +
+                                 std::to_string(g_sbs.diagWaitMs / 300.0) +
+                                 " ms, blocked " + std::to_string(g_sbs.diagBlocked) + "/300");
+                    g_sbs.diagWaitMs = 0.0; g_sbs.diagBlocked = 0;
+                }
+            }
+
+            // Pool has RESET_COMMAND_BUFFER_BIT, so BeginCommandBuffer
+            // implicitly resets the (previously executable) command buffer.
+            VkCommandBufferBeginInfo bi = { VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO };
+            bi.flags = VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT;
+            vkd.BeginCommandBuffer(s.cmd, &bi);
+
+            VkImageMemoryBarrier b = { VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER };
+            b.image = image;
+            b.oldLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+            b.newLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+            b.srcAccessMask = 0; b.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT;
+            b.srcQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+            b.dstQueueFamilyIndex = VK_QUEUE_FAMILY_IGNORED;
+            b.subresourceRange = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 1, 0, 1 };
+            vkd.CmdPipelineBarrier(s.cmd, VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
+                                   VK_PIPELINE_STAGE_TRANSFER_BIT, 0, 0, nullptr,
+                                   0, nullptr, 1, &b);
+
+            VkBufferImageCopy region = {};
+            region.imageSubresource = { VK_IMAGE_ASPECT_COLOR_BIT, 0, 0, 1 };
+            region.imageExtent = { w, h, 1 };
+            vkd.CmdCopyImageToBuffer(s.cmd, image,
+                                     VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
+                                     s.staging, 1, &region);
+
+            b.oldLayout = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL;
+            b.newLayout = VK_IMAGE_LAYOUT_PRESENT_SRC_KHR;
+            b.srcAccessMask = VK_ACCESS_TRANSFER_READ_BIT; b.dstAccessMask = 0;
+            vkd.CmdPipelineBarrier(s.cmd, VK_PIPELINE_STAGE_TRANSFER_BIT,
+                                   VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT, 0, 0, nullptr,
+                                   0, nullptr, 1, &b);
+            vkd.EndCommandBuffer(s.cmd);
+
+            VkPipelineStageFlags waitStage = VK_PIPELINE_STAGE_TRANSFER_BIT;
+            VkSubmitInfo si = { VK_STRUCTURE_TYPE_SUBMIT_INFO };
+            si.waitSemaphoreCount = waitSem ? 1 : 0;
+            si.pWaitSemaphores = waitSem ? &waitSem : nullptr;
+            si.pWaitDstStageMask = waitSem ? &waitStage : nullptr;
+            si.commandBufferCount = 1;
+            si.pCommandBuffers = &s.cmd;
+            si.signalSemaphoreCount = 1;
+            si.pSignalSemaphores = &s.sem;
+            if (vkd.QueueSubmit(dev->queue, 1, &si, s.fence) != VK_SUCCESS)
+                return VK_NULL_HANDLE;
+
+            s.inFlight = true;
+            g_sbs.cur = (g_sbs.cur + 1) % SBS_SLOTS;
+            return s.sem;
+        }
+    } // anonymous namespace
+
     // layer book-keeping information, to store dispatch tables by key
     std::unordered_map<void*, InstanceDispatch>                           instanceDispatchMap;
     std::unordered_map<void*, VkInstance>                                 instanceMap;
